{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/startup_context.sh",
            "statusMessage": "Preparing DeepWork context"
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post_compact.sh",
            "statusMessage": "Restoring DeepWork workflow context"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|exec_command",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post_commit_reminder.sh",
            "statusMessage": "Checking DeepWork review reminder"
          }
        ]
      },
      {
        "matcher": "apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/deepschema_write.sh",
            "statusMessage": "Checking DeepWork schemas"
          }
        ]
      }
    ]
  }
}
